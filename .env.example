OPENWEATHER_API_KEY=
# Dashboard/city heroes default to Esri satellite maps (Leaflet). Unsplash is for journal/photo mode.
UNSPLASH_ACCESS_KEY=
# Optional — third photo provider after Unsplash + Wikimedia Commons (journal / photo-mode heroes).
PEXELS_API_KEY=
# Satellite map hero (default on). Set to 0 to use photos instead (Unsplash → Wikimedia → Pexels).
# NEXT_PUBLIC_CITY_HERO_OSM=0
# Home ads + journal teaser are on by default. Set to 0 for a leaner UI.
# NEXT_PUBLIC_SHOW_HOME_STRETCH=0
# Set to 0 to hide showcase cities in the popular-searches strip when it has no real traffic.
# NEXT_PUBLIC_SHOW_DEMO_POPULAR_SEARCHES=0
# Opt-in Google Street View when the map hero is off (requires Maps billing).
# NEXT_PUBLIC_CITY_HERO_STREET_VIEW=1
# Optional Maps Embed API key for official Street View iframes (billing applies).
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
RESEND_API_KEY=
RESEND_FROM_EMAIL=info@meridianweather.co.uk
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=info@meridianweather.co.uk
# Amazon SES (optional connector — uses AWS SigV4 SendEmail v2 API)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SES_REGION=eu-west-1
AWS_SES_FROM_EMAIL=info@meridianweather.co.uk
# SMTP (Gandi / custom — activate emailProvider=smtp in admin or platform_settings)
SMTP_HOST=mail.gandi.net
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=info@meridianweather.co.uk
SMTP_SECURE=0
DATABASE_PATH=./data/meridian.db
# Required in production — Bearer token for /api/cron/* (denied when unset in production).
CRON_SECRET=
# Required to sign admin sessions + encrypt connector secrets (never reuse as a login password).
ADMIN_SECRET=
# Root admin login password (bootstrap ADMIN_EMAIL only). Keep real values in .env.local only.
ADMIN_PASSWORD=
ADMIN_EMAIL=
ADMIN_DISPLAY_NAME=Root
# Dev only: set to 1 with NODE_ENV=development and no ADMIN_SECRET for local admin bypass.
# ALLOW_DEV_ADMIN_BYPASS=1
# Logging — default info; set LOG_TO_FILE=0 to disable data/logs/*.jsonl
# LOG_LEVEL=info
# LOG_TO_FILE=0
NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
# AdSense publisher ID (ca-pub-…). Public once live; defaults to Meridian’s ca-pub in code if unset.
GOOGLE_ADSENSE_CLIENT_ID=ca-pub-2983984988419906
# Display ad unit slot IDs from the AdSense dashboard (required for filled <ins> units).
# Create units in AdSense → Ads → By ad unit, then paste numeric slot IDs here.
GOOGLE_ADSENSE_SLOT_DASHBOARD=
GOOGLE_ADSENSE_SLOT_HERO=
GOOGLE_ADSENSE_SLOT_RECENT=
GOOGLE_ADSENSE_SLOT_CITY_DETAIL=
GOOGLE_ADSENSE_SLOT_WEATHER_MID=
GOOGLE_ADSENSE_SLOT_DEFAULT=
# AdSense Auto ads are preferred once fixed AdSlot placeholders are removed from the UI.
# Enable Auto ads in the AdSense dashboard; Meridian keeps the loader script for verification.
# Stripe ad-free billing (optional). Checkout CTAs stay disabled until these are set.
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ADFEEE_MONTHLY=
STRIPE_PRICE_ADFEEE_ANNUAL=
STRIPE_PRICE_ADFEEE_LIFETIME=
# HMAC secret for signed ad-free license cookies (falls back to ADMIN_SECRET if unset).
ADFEEE_LICENSE_SECRET=
# AdSense Management API (admin earnings dashboard). OAuth web client from Google Cloud Console.
GOOGLE_ADSENSE_OAUTH_CLIENT_ID=
GOOGLE_ADSENSE_OAUTH_CLIENT_SECRET=
# Optional; defaults to ${NEXT_PUBLIC_APP_URL}/api/admin/adsense/oauth/callback
GOOGLE_ADSENSE_OAUTH_REDIRECT_URI=
