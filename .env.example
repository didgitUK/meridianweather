OPENWEATHER_API_KEY=
# Unsplash Access Key enables live location heroes. Without it, public/hero static SVGs are used.
UNSPLASH_ACCESS_KEY=
UNSPLASH_SECRET_KEY=
UNSPLASH_APPLICATION_ID=
RESEND_API_KEY=
RESEND_FROM_EMAIL=alerts@meridianweather.co.uk
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=alerts@meridianweather.co.uk
# Amazon SES (optional connector — send path scaffolded until wired)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SES_REGION=eu-west-1
AWS_SES_FROM_EMAIL=alerts@meridianweather.co.uk
DATABASE_PATH=./data/meridian.db
CRON_SECRET=
ADMIN_SECRET=
# Root admin login (keep real values in .env.local only — never commit).
ADMIN_PASSWORD=
ADMIN_EMAIL=
ADMIN_DISPLAY_NAME=Root
NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
# AdSense publisher ID (ca-pub-…). Keep in .env.local only — never commit real values.
GOOGLE_ADSENSE_CLIENT_ID=
# Display ad unit slot IDs from the AdSense dashboard (optional until units are created).
GOOGLE_ADSENSE_SLOT_DASHBOARD=
GOOGLE_ADSENSE_SLOT_HERO=
GOOGLE_ADSENSE_SLOT_RECENT=
GOOGLE_ADSENSE_SLOT_CITY_DETAIL=
GOOGLE_ADSENSE_SLOT_DEFAULT=
# AdSense Management API (admin earnings dashboard). OAuth web client from Google Cloud Console.
GOOGLE_ADSENSE_OAUTH_CLIENT_ID=
GOOGLE_ADSENSE_OAUTH_CLIENT_SECRET=
# Optional; defaults to ${NEXT_PUBLIC_APP_URL}/api/admin/adsense/oauth/callback
GOOGLE_ADSENSE_OAUTH_REDIRECT_URI=
