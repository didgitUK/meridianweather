{
  "name": "meridian-weather",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build",
    "start": "node -r ./scripts/load-gandi-env.cjs ./node_modules/next/dist/bin/next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "check:i18n": "node scripts/check-i18n-keys.mjs",
    "verify": "npm run lint && npm run check:i18n && npm run test && npm run build",
    "audit:deps": "npm audit --omit=dev",
    "copy:icons": "node scripts/copy-weather-icons.mjs",
    "postinstall": "node scripts/copy-weather-icons.mjs && ([ -z \"$GANDI\" ] || NODE_OPTIONS='--max-old-space-size=768' npm run build)",
    "deploy:gandi": "bash scripts/deploy-gandi.sh",
    "deploy:gandi:env": "bash scripts/gandi-upload-env.sh",
    "seed:checks": "node scripts/seed-recent-checks.mjs",
    "seed:uk-places": "node scripts/seed-uk-places.mjs",
    "populate:place-content": "PLACE_CONTENT_LLM_MODE=${PLACE_CONTENT_LLM_MODE:-stub} node --import ./scripts/alias-loader.mjs scripts/populate-place-content.mjs",
    "generate:vapid": "node scripts/generate-vapid-keys.mjs",
    "prefetch:place-heroes": "node scripts/prefetch-place-heroes.mjs",
    "backfill:city-slugs": "node scripts/backfill-city-slugs.mjs",
    "email": "email dev --dir src/emails"
  },
  "engines": {
    "node": ">=20"
  },
  "config": {
    "NODE_ENV": "development"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@meteocons/svg-static": "^0.1.0",
    "@next/third-parties": "^16.2.10",
    "@react-email/components": "^1.0.12",
    "@tiptap/extension-link": "^3.27.4",
    "@tiptap/pm": "^3.27.4",
    "@tiptap/react": "^3.27.4",
    "@tiptap/starter-kit": "^3.27.4",
    "better-sqlite3": "^12.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.23.0",
    "next": "16.2.10",
    "next-intl": "^4.13.1",
    "nodemailer": "^9.0.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-email": "^6.6.8",
    "recharts": "^3.9.2",
    "resend": "^6.17.2",
    "sonner": "^2.0.7",
    "stripe": "^22.3.2",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "uuid": "^14.0.1",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/leaflet": "^1.9.21",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "vitest": "^4.1.10"
  }
}
