# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/

# runtime structured logs (created by logger.js)
/data/logs/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# local editor / agent scratch
.cursor/
AGENTS.md
CLAUDE.md
SCOPE.md
REVIEWER.md
docs/STUDY-BACKEND.md

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local SQLite (auto-created at runtime)
/data/
*.db

# duplicate brand asset (canonical: public/brand/whitewind.png)
/whitewind.png
/Meridian*.png
